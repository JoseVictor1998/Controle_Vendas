@page "/fila-arte"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using ComunicacaoVisual.Client.Models
@using ComunicacaoVisual.Client.Services
@attribute [Authorize(Roles = "God,Admin,Arte,Vendedor")]
@inject IJSRuntime JS
@inject FilaArteService Service
@inject AuthenticationStateProvider AuthStateProvider
@inject HttpClient Http
@using System.Net.Http
@using System.Net.Http.Headers

<style>
    .page-container { background-color: #0f172a; min-height: 100vh; padding: 2rem; color: #f8fafc; }
    .header-section { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }

    .custom-table { width: 100%; border-collapse: separate; border-spacing: 0 0.75rem; }
    .custom-table thead th { color: #94a3b8; text-transform: uppercase; font-size: 0.75rem; padding: 1rem; border: none; }

    .row-base { background-color: #1e293b; transition: all 0.2s; border-radius: 8px; }
    .row-base:hover {
        position: relative; /* Necessário para o z-index funcionar em  */
        z-index: 100;        /* Coloca a linha atual e seu conteúdo no topo da pilha */
    }

    .row-delayed { background-color: rgba(127, 29, 29, 0.3) !important; border-left: 4px solid #ef4444; }
    
    /* TOOLTIP DE OBSERVAÇÕES */
    .obs-box { cursor: help; position: relative; display: inline-block; }
   .obs-content { 
        display: none; 
        position: absolute; 
        z-index: 99999 !important; /* Continua sendo o mais alto dentro da linha */
        
        /* 🚀 FUNDO 100% SÓLIDO: Não deixa nada de trás aparecer */
        background-color: #1e293b !important; 
        opacity: 1 !important; 
        
        border: 1px solid #fedf00; 
        padding: 1rem; 
        border-radius: 0.5rem; 
        width: 320px; 
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.9); 
        top: 25px; 
        left: 0;
    }

    /* 🚀 O SEGREDO: Quando você passa o mouse, o "pai" da caixa também sobe na pilha */
    .obs-box:hover {
        z-index: 10000;
        position: relative;
    }

    .obs-box:hover .obs-content { 
        display: block; 
    }

    /* 🚀 BOTÕES MAIS EXPLICATIVOS */
    .btn-action { 
        background: #334155; color: #fedf00; border: 1px solid #475569; 
        padding: 6px 12px; border-radius: 6px; font-size: 0.7rem; font-weight: 600;
        cursor: pointer; display: inline-flex; align-items: center; gap: 6px; 
        transition: all 0.2s; text-transform: uppercase;
    }
    .btn-action:hover { background: #fedf00; color: #0f172a; border-color: #fedf00; }
    
    .status-select { 
        background: #0f172a; color: #fedf00; border: 1px solid #334155; 
        border-radius: 6px; font-size: 0.75rem; padding: 4px 8px; height: 32px;
    }

    .foto-miniatura {
        width: 50px; height: 50px; object-fit: cover; border-radius: 8px; 
        border: 1px solid #334155; transition: transform 0.3s ease; cursor: zoom-in;
    }
    .foto-miniatura:hover { transform: scale(4); z-index: 10000; position: relative; box-shadow: 0 0 20px rgba(0,0,0,0.8); }
</style>

<div class="page-container">
    <div class="header-section">
        <div>
            <h1 style="font-size: 1.5rem; font-weight: 700;">Fila de Arte</h1>
            <p style="color: #94a3b8; font-size: 0.875rem;">Pedidos aguardando criação/aprovação de arte</p>
        </div>
        @if (lista?.Count > 0)
        {
            <div style="background:#fedf00;color:#0f172a;padding:.5rem 1rem;border-radius:9999px;font-weight:bold;">
                @lista.Count Itens na fila
            </div>
        }
    </div>

    <table class="custom-table">
        <thead>
            <tr>
                <th>Foto</th>
                <th>Tempo</th>
                <th>OS</th>
                <th>Cliente / Obs</th>
                <th>Produto</th>
                <th>Dimensões</th>
                <th>Qtd</th>
                <th>Status</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @if (lista != null)
            {
                @foreach (var item in lista)
                {
                    var dias = item.DiasAguardandoArte ?? 0;
                    <tr class="row-base @(dias > 2 ? "row-delayed" : "")">
                        
                        @* 1. FOTO: Com botão de câmera específico *@
                        <td style="width: 100px; padding: 1rem; text-align: center;">
                           @if (!string.IsNullOrEmpty(item.CaminhoFoto))
                            {
                               @* 🚀 Lógica inteligente: Verifica se o banco já tem 'http' ou se precisa do endereço da API *@
                                  var linkFinal = item.CaminhoFoto.Contains("http") 
                                      ? item.CaminhoFoto 
                                    : $"{Http.BaseAddress}{item.CaminhoFoto.TrimStart('/')}";

                                <img src="@($"{linkFinal}?t={DateTime.Now.Ticks}")" 
                              class="foto-miniatura" 
                               alt="Preview" />
                            }
                            else
                            {
                                <div style="width: 50px; height: 50px; background: #1e293b; display: flex; align-items: center; justify-content: center; border-radius: 8px; margin: 0 auto;">
                                    <i class="oi oi-image" style="color: #475569;"></i>
                                </div>
                            }
                            @* 📷 BOTÃO DA CÂMERA: Muda a miniatura *@
                            <label class="btn-action" style="margin-top: 8px; padding: 2px 6px; font-size: 0.6rem;" title="Mudar Foto de Exibição">
                                <i class="oi oi-camera-slr"></i> FOTO
                                <InputFile OnChange="@(e => UploadFotoMiniatura(e, item.ItemId))" style="display:none;" />
                            </label>
                        </td>

                        <td style="padding:1rem;">@(dias == 0 ? "Novo" : $"{dias}d")</td>
                        <td style="padding:1rem; font-weight: 700;">@item.OS</td>
                        <td style="padding:1rem;">
                            <span style="display: block; font-weight: 600;">@item.Cliente</span>
                            <div class="obs-box">
                                <span style="color:#94a3b8; text-decoration: underline; font-size: 0.8rem;">Ver Observações</span>
                                <div class="obs-content">
                                    <strong>Geral:</strong> @(item.ObservacaoGeral ?? "-")<br /><br />
                                    <strong>Técnica:</strong> @(item.ObservacaoTecnica ?? "-")
                                </div>
                            </div>
                        </td>
                        <td style="padding:1rem;">@item.Produto</td>
                        <td style="padding:1rem;">@item.Largura.ToString("N2") x @item.Altura.ToString("N2")</td>
                        <td style="padding:1rem;">@item.Quantidade</td>
                        <td style="padding:1rem;">
                            <span style="background: #fedf00; color: #0f172a; padding: 2px 8px; border-radius: 4px; font-weight: bold; font-size: 0.75rem;">
                                @item.StatusArte
                            </span>
                        </td>

                        @* 9. AÇÕES: Botões explicativos com texto *@
                        <td style="padding:1rem;">
                            <div style="display: flex; flex-direction: column; gap: 6px;">
                                
                                <select class="status-select" @onchange="@(e => AlterarStatus(e, item.ItemId))">
                                    <option value="2" selected="@(item.StatusArte == "Enviada")">Enviada</option>
                                    <option value="3" selected="@(item.StatusArte == "Em Correção")">Em Correção</option>
                                    <option value="4">Aprovar</option>
                                    <option value="5">Reprovar</option>
                                </select>

                                <div style="display: flex; gap: 6px;">
                                    @if (item.ArquivoId > 0)
                                    {
                                        <button class="btn-action" @onclick="() => BaixarEProcessar(item.ArquivoId)">
                                            <i class="oi oi-data-transfer-download"></i> BAIXAR
                                        </button>
                                    }

                                    @* ☁️ BOTÃO DA NUVEM: Sobe o arquivo real (PDF/Arte) *@
                                    <label class="btn-action">
                                        <i class="oi oi-cloud-upload"></i> SUBIR ARTE
                                        <InputFile OnChange="@(e => UploadArquivoArte(e, item.ItemId))" style="display:none;" />
                                    </label>
                                </div>

                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@code {
    private List<FilaArteDTO>? lista;
    private int usuarioLogadoId;

    protected override async Task OnInitializedAsync()
    {
        await ObterUsuarioLogado();
        await CarregarFila();
    }

    private async Task ObterUsuarioLogado()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var claimId = user.FindFirst("UsuarioId")?.Value;
        if (!int.TryParse(claimId, out usuarioLogadoId)) usuarioLogadoId = 2; 
    }

    private async Task CarregarFila()
    {
        try { lista = await Service.Listar(); }
        catch { lista = new(); }
    }

    private async Task BaixarEProcessar(int? arquivoId)
{
    if (arquivoId == null || arquivoId == 0) return;

    var (bytes, type, name) = await Service.BaixarArquivo(arquivoId.Value);
    
    if (bytes != null)
    {
        using var stream = new MemoryStream(bytes);
        using var streamRef = new DotNetStreamReference(stream);
        
        // 🚀 PASSAMOS O 'type' (ex: application/pdf) para o JS não se perder
        await JS.InvokeVoidAsync("downloadFileFromStream", name, streamRef, type);
    }
}

    private async Task AlterarStatus(ChangeEventArgs e, int itemId)
    {
        if (int.TryParse(e.Value?.ToString(), out int novoStatusId))
        {
            var sucesso = await Service.MudarStatus(itemId, novoStatusId, usuarioLogadoId);
            if (sucesso) await CarregarFila();
        }
    }

    private async Task UploadFotoMiniatura(InputFileChangeEventArgs e, int itemId)
{
    var content = new MultipartFormDataContent();
    
    // 🚀 O SEGREDO: Definir o tipo do conteúdo (image/jpeg, etc)
    var fileContent = new StreamContent(e.File.OpenReadStream(maxAllowedSize: 1024 * 1024 * 15));
    fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(e.File.ContentType);
    
    content.Add(fileContent, "file", e.File.Name);

    var res = await Http.PostAsync($"api/Producao/UploadFotoArte/{itemId}", content);

    if (res.IsSuccessStatusCode)
    {
        await CarregarFila(); // Recarrega a lista para a foto atualizar na tela
        StateHasChanged();    // Força o Blazor a redesenhar a página
    }
}

    private async Task UploadArquivoArte(InputFileChangeEventArgs e, int itemId)
    {
        var sucesso = await Service.VincularArte(itemId, e.File);
        if (sucesso) 
        {
            await CarregarFila();
            await JS.InvokeVoidAsync("alert", "Arte final vinculada com sucesso!");
        }
    }
}