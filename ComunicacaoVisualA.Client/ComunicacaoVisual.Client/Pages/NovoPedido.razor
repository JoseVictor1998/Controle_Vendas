@page "/novo-pedido"
@using System.Linq
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Forms
@using ComunicacaoVisual.Client.Models

@inject HttpClient Http
@inject ComunicacaoVisual.Client.Services.PedidoService PedidoService
@inject NavigationManager Nav
@inject IJSRuntime JS

<style>
    .page { background:#0f172a; min-height:100vh; padding:2rem; color:#f8fafc; }
    .container { max-width: 880px; margin: 0 auto; }
    .card { background:#1e293b; border:1px solid #334155; border-radius:14px; padding:1.25rem; margin-bottom: 1rem; }
    .item-card { background:#0f172a; border:1px solid #475569; border-radius:10px; padding:1rem; margin-bottom: 1rem; position: relative; }
    .muted { color:#e2e8f0; }
    .label { color:#cbd5e1; font-size:.75rem; text-transform:uppercase; letter-spacing:.06em; margin-bottom:.25rem; display:block; }
    .input, .textarea { width:100%; background:#1e293b; border:1px solid #475569; border-radius:10px; padding:.6rem .75rem; color:#fff; }
    .textarea { min-height: 92px; resize: vertical; }
    .grid2 { display:grid; grid-template-columns: 1fr 1fr; gap:1rem; }
    .grid3 { display:grid; grid-template-columns: 1fr 1fr 1fr; gap:1rem; }
    .btn { border-radius: 10px; padding:.65rem .9rem; border:1px solid transparent; cursor:pointer; font-weight:600; }
    .btn-yellow { background:#fedf00; color:#0f172a; }
    .btn-yellow:disabled { opacity:.55; cursor:not-allowed; }
    .btn-green { background:#009b3a; color:#fff; }
    .btn-outline { background:transparent; border-color:#475569; color:#cbd5e1; }
    .btn-outline:hover { background:#334155; }
    .btn-danger { background: rgba(239,68,68,.12); border:1px solid rgba(239,68,68,.35); color:#fecaca; padding: 0.3rem 0.6rem; border-radius: 6px;}
    .row { display:flex; gap:.75rem; align-items:center; flex-wrap:wrap; }
    .pill { display:inline-block; padding:.18rem .5rem; border-radius:999px; background:#0b1224; border:1px solid #334155; color:#cbd5e1; font-size:.75rem; }
    .preview { width: 56px; height: 56px; border-radius: 12px; object-fit: cover; border:1px solid #475569; }
    .alert { border-radius: 12px; padding:.75rem 1rem; margin-top: 1rem; }
    .ok { background: rgba(34,197,94,.12); border:1px solid rgba(34,197,94,.35); color:#bbf7d0; }
    .err { background: rgba(239,68,68,.12); border:1px solid rgba(239,68,68,.35); color:#fecaca; }
    .hint { color:#94a3b8; font-size:.8rem; margin-top:.35rem; }
    .file-hidden { display:none !important; }
</style>

<div class="page">
    <div class="container">
        <div style="margin-bottom: 1rem;">
            <h1 style="font-size: 1.6rem; font-weight: 800;">Novo Pedido</h1>
            <div class="muted">Crie um pedido com múltiplos itens para produção</div>
        </div>

        @if (carregandoListas)
        {
            <div class="card">
                <div class="muted">Carregando clientes e produtos...</div>
            </div>
        }
        else if (step == 2)
        {
            <h2 style="font-size: 1.2rem; font-weight: 800; margin: 1rem 0; color:#fff;">
                Confirmação do Pedido
            </h2>

            <div class="card">
                <div class="grid2" style="margin-bottom: 1rem;">
                    <div>
                        <div style="color:#94a3b8; font-size:.75rem;">Cliente</div>
                        <div style="font-weight:800; color:#fff;">@clienteNome</div>
                    </div>
                    <div>
                        <div style="color:#94a3b8; font-size:.75rem;">OS Externa</div>
                        <div style="font-weight:800; color:#fff;">@model.OsExterna</div>
                    </div>
                    <div>
                        <div style="color:#94a3b8; font-size:.75rem;">Vendedor</div>
                        <div style="font-weight:800; color:#fff;">@vendedorNome</div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(model.ObservacaoGeral))
                    {
                        <div>
                            <div style="color:#94a3b8; font-size:.75rem;">Obs. Geral</div>
                            <div style="color:#fff;">@model.ObservacaoGeral</div>
                        </div>
                    }
                </div>

                <h3 style="font-size: 1rem; font-weight: 700; color:#fedf00; margin-top: 1.5rem; margin-bottom: 0.5rem;">Itens do Pedido (@model.Itens.Count)</h3>
                
                @foreach (var item in model.Itens)
                {
                    <div class="item-card">
                        <div class="grid3">
                            <div>
                                <span style="color:#94a3b8; font-size:.75rem;">Produto:</span><br/>
                                @* 🚀 COR BRANCA FORÇADA AQUI *@
                                <strong style="color: #ffffff; font-size: 1rem;">@item.NomeProdutoSelecionado</strong>
                            </div>
                            <div>
                                <span style="color:#94a3b8; font-size:.75rem;">Dimensões:</span><br/>
                                <span style="color: #ffffff;">@item.Largura x @item.Altura</span>
                            </div>
                            <div>
                                <span style="color:#94a3b8; font-size:.75rem;">Qtd:</span><br/>
                                <strong style="color: #ffffff; font-size: 1rem;">@item.Quantidade</strong>
                            </div>
                        </div>
                        
                        @if (!string.IsNullOrWhiteSpace(item.ObservacaoTecnica))
                        {
                            <div style="margin-top: 0.75rem; font-size: 0.85rem; color:#cbd5e1;">
                                <em>Obs: @item.ObservacaoTecnica</em>
                            </div>
                        }

                        @* 🚀 MOSTRANDO A ARTE NA REVISÃO *@
                        @if (!string.IsNullOrWhiteSpace(item.CaminhoFoto))
                        {
                            <div style="margin-top: 0.75rem;">
                                <span style="color:#94a3b8; font-size:.75rem;">Arte Anexada:</span><br/>
                                <img src="@item.PreviewUrl" style="width: 48px; height: 48px; border-radius: 6px; object-fit: cover; border: 1px solid #475569;" />
                            </div>
                        }
                    </div>
                }

                <div class="row" style="padding-top: 1rem;">
                    <button class="btn btn-outline" @onclick="() => step = 1" disabled="@salvando">Voltar</button>
                    <button class="btn btn-green" style="flex:1;" @onclick="Confirmar" disabled="@salvando">
                        @(salvando ? "Enviando..." : "Confirmar Pedido")
                    </button>
                </div>

                @if (!string.IsNullOrWhiteSpace(msg))
                {
                    <div class="alert @(ok ? "ok" : "err")">@msg</div>
                }
            </div>
        }
        else
        {
            <div class="card">
                <h3 style="font-size: 1.1rem; font-weight: 700; color:#fff; margin-bottom: 1rem;">Dados Gerais do Pedido</h3>
                <div class="grid2">
                    <div>
                        <label class="label">Cliente</label>
                        <input class="input" list="clientesList" placeholder="Digite o nome do cliente..." @bind="clienteNome" @bind:event="oninput" />
                        <datalist id="clientesList">
                            @foreach (var c in clientes) { <option value="@c.Nome"></option> }
                        </datalist>
                    </div>

                    <div>
                        <label class="label">OS Externa (até 6)</label>
                        <input class="input" maxlength="6" @bind="model.OsExterna" />
                    </div>
                </div>

                <div style="margin-top: 1rem;">
                    <label class="label">Observação Geral (Para todos os itens)</label>
                    <textarea class="textarea" @bind="model.ObservacaoGeral" style="min-height: 60px;"></textarea>
                </div>
            </div>

            <h3 style="font-size: 1.1rem; font-weight: 700; color:#fff; margin: 1.5rem 0 1rem 0;">Materiais / Itens</h3>
            
            @for (int i = 0; i < model.Itens.Count; i++)
            {
                var itemIndex = i; 
                var item = model.Itens[itemIndex];

                <div class="item-card">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 1rem;">
                        <h4 style="margin: 0; color: #fedf00;">Item @(itemIndex + 1)</h4>
                        @if (model.Itens.Count > 1)
                        {
                            <button class="btn btn-danger" @onclick="() => RemoverItem(itemIndex)">Remover</button>
                        }
                    </div>

                    <div style="margin-bottom: 1rem;">
                        <label class="label">Produto / Material</label>
                        <input class="input" list="produtosList" placeholder="Ex: Lona 440g, Adesivo Vinil..." @bind="item.NomeProdutoSelecionado" @bind:event="oninput" />
                        <datalist id="produtosList">
                            @foreach (var p in produtos) { <option value="@p.Nome"></option> }
                        </datalist>
                    </div>

                    <div class="grid3">
                        <div>
                            <label class="label">Largura</label>
                            <input class="input" type="number" step="0.01" @bind="item.Largura" />
                        </div>
                        <div>
                            <label class="label">Altura</label>
                            <input class="input" type="number" step="0.01" @bind="item.Altura" />
                        </div>
                        <div>
                            <label class="label">Qtd.</label>
                            <input class="input" type="number" min="1" @bind="item.Quantidade" />
                        </div>
                    </div>

                    <div style="margin-top: 1rem;">
                        <label class="label">Observação Técnica</label>
                        <textarea class="textarea" @bind="item.ObservacaoTecnica" style="min-height: 60px;"></textarea>
                    </div>

                    @* 🚀 O UPLOAD VOLTOU! AGORA ELE É INDIVIDUAL POR ITEM *@
                    <div style="margin-top: 1rem;">
                        <label class="label">Foto do Produto / Arte Original</label>
                        <div class="row">
                            <label class="btn btn-outline" style="display:inline-flex; align-items:center; gap:.5rem;">
                                @(item.FazendoUpload ? "Enviando..." : "Selecionar imagem")
                                <InputFile OnChange="@(e => OnFileSelected(e, item))" accept="image/*" class="file-hidden" disabled="@item.FazendoUpload" />
                            </label>

                            @if (!string.IsNullOrWhiteSpace(item.FileName))
                            {
                                <span class="hint" style="color:#fff;">@item.FileName</span>
                            }

                            @if (!string.IsNullOrWhiteSpace(item.PreviewUrl))
                            {
                                <img class="preview" src="@item.PreviewUrl" alt="Prévia" />
                            }
                        </div>

                        @if (!string.IsNullOrWhiteSpace(item.CaminhoFoto))
                        {
                            <div class="hint" style="color:#10b981;">✔ Imagem anexada com sucesso e pronta para salvar!</div>
                        }
                    </div>
                </div>
            }

            <button class="btn btn-outline" style="width:100%; margin-bottom: 1.5rem; border-style: dashed; border-color: #fedf00; color: #fedf00;" @onclick="AdicionarNovoItem">
                ➕ Adicionar Outro Material
            </button>

            <div class="card">
                <button class="btn btn-yellow" style="width:100%;" @onclick="Revisar" disabled="@(!CanProceed)">
                    Revisar Pedido Completo
                </button>

                @if (!string.IsNullOrWhiteSpace(msg))
                {
                    <div class="alert @(ok ? "ok" : "err")">@msg</div>
                }
            </div>
        }
    </div>
</div>

@code {
    private class ClienteOption { public int Id { get; set; } public string Nome { get; set; } = ""; }
    private class ProdutoOption { public int Id { get; set; } public string Nome { get; set; } = ""; }
    private class UploadResult { public string Url { get; set; } = ""; }

    private int step = 1;
    private bool carregandoListas = true;
    private bool salvando;
    private bool ok;
    private string? msg;

    private string clienteNome = "";
    private string vendedorNome = "";

    private List<ClienteOption> clientes = new();
    private List<ProdutoOption> produtos = new();

    private CriarPedidoComItemInput model = new();

    protected override async Task OnInitializedAsync()
    {
        model.Itens.Add(new NovoItemDTO());

        try
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");
            if (!string.IsNullOrWhiteSpace(token))
                Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

            vendedorNome = await JS.InvokeAsync<string>("localStorage.getItem", "userName") ?? "";
            model.VendedorID = await GetUsuarioIdFromJwtAsync();

            clientes = await Http.GetFromJsonAsync<List<ClienteOption>>("api/Producao/ClientesListar") ?? new();
            produtos  = await Http.GetFromJsonAsync<List<ProdutoOption>>("api/Producao/TiposProdutoListar") ?? new();
        }
        catch (Exception ex)
        {
            msg = $"Erro ao carregar listas: {ex.Message}";
            ok = false;
        }
        finally
        {
            carregandoListas = false;
        }
    }

    private void AdicionarNovoItem()
    {
        model.Itens.Add(new NovoItemDTO());
    }

    private void RemoverItem(int index)
    {
        if (model.Itens.Count > 1)
        {
            model.Itens.RemoveAt(index);
        }
    }

    // 🚀 O NOVO MÉTODO DE UPLOAD QUE SABE EXATAMENTE QUAL ITEM ESTÁ RECEBENDO A ARTE
    private async Task OnFileSelected(InputFileChangeEventArgs e, NovoItemDTO itemAtual)
    {
        try
        {
            itemAtual.FazendoUpload = true;
            StateHasChanged(); 

            var file = e.File;
            if (file is null) return;

            itemAtual.FileName = file.Name;

            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);

            itemAtual.PreviewUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";
            StateHasChanged();

            var content = new MultipartFormDataContent();
            var fileContent = new ByteArrayContent(ms.ToArray());
            fileContent.Headers.ContentType = new MediaTypeHeaderValue(file.ContentType);
            content.Add(fileContent, "file", file.Name);

            var resp = await Http.PostAsync("api/Upload/Imagem", content);

            if (resp.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                ok = false;
                msg = "Sessão expirada. Faça login novamente.";
                return;
            }

            resp.EnsureSuccessStatusCode();

            var result = await resp.Content.ReadFromJsonAsync<UploadResult>();
            if (result is not null && !string.IsNullOrWhiteSpace(result.Url))
            {
                itemAtual.CaminhoFoto = result.Url;
            }
            else
            {
                ok = false;
                msg = "Upload realizado, mas a API não retornou a URL.";
            }
        }
        catch (Exception ex)
        {
            ok = false;
            msg = $"Erro ao enviar imagem: {ex.Message}";
        }
        finally
        {
            itemAtual.FazendoUpload = false;
            StateHasChanged();
        }
    }

    private bool CanProceed =>
        ResolveIdsFromNames() &&
        !string.IsNullOrWhiteSpace(model.OsExterna) &&
        model.OsExterna.Length <= 6 &&
        model.VendedorID > 0 &&
        model.Itens.All(i => i.Largura > 0 && i.Altura > 0 && i.Quantidade > 0 && i.TipoProdutoId > 0);

    private bool ResolveIdsFromNames()
    {
        var c = clientes.FirstOrDefault(x => string.Equals(x.Nome, clienteNome, StringComparison.OrdinalIgnoreCase));
        model.ClienteId = c?.Id ?? 0;

        bool todosProdutosResolvidos = true;
        foreach (var item in model.Itens)
        {
            var p = produtos.FirstOrDefault(x => string.Equals(x.Nome, item.NomeProdutoSelecionado, StringComparison.OrdinalIgnoreCase));
            item.TipoProdutoId = p?.Id ?? 0;
            if (item.TipoProdutoId == 0) todosProdutosResolvidos = false;
        }

        return model.ClienteId > 0 && todosProdutosResolvidos;
    }

    private void Revisar()
    {
        msg = null;
        if (!CanProceed)
        {
            ok = false;
            msg = "Preencha os campos obrigatórios e garanta que todos os itens têm produtos válidos selecionados.";
            return;
        }
        step = 2;
    }

    private async Task Confirmar()
    {
        salvando = true;
        msg = null;

        ResolveIdsFromNames();

        var (success, message) = await PedidoService.CriarPedidoAsync(model);

        ok = success;
        msg = message;
        salvando = false;

        if (ok)
        {
            model = new() { VendedorID = model.VendedorID };
            model.Itens.Add(new NovoItemDTO());
            clienteNome = "";
            step = 1;
        }
    }

    private async Task<int> GetUsuarioIdFromJwtAsync()
    {
        var token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");
        if (string.IsNullOrWhiteSpace(token)) return 0;
        try
        {
            var parts = token.Split('.');
            if (parts.Length != 3) return 0;
            var payload = parts[1].Replace('-', '+').Replace('_', '/');
            switch (payload.Length % 4)
            {
                case 2: payload += "=="; break;
                case 3: payload += "="; break;
            }
            var jsonBytes = Convert.FromBase64String(payload);
            using var doc = JsonDocument.Parse(jsonBytes);
            if (doc.RootElement.TryGetProperty("UsuarioId", out var idProp))
            {
                var s = idProp.GetString();
                if (int.TryParse(s, out var id)) return id;
            }
            return 0;
        }
        catch { return 0; }
    }
}